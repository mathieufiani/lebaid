# Supabase — Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Telegram Bot (BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHANNEL_ID=@lebaid_alerts  # ou l'ID numérique du channel

# Optionnel : geocodage OpenCage (alternative à Nominatim)
OPENCAGE_API_KEY=

# Upstash Redis — Rate limiting (console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — Email notifications (resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lebaid.app
ADMIN_EMAIL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001
